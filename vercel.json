{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/health-check",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/health-check",
      "schedule": "0 22 * * *"
    }
  ]
}
