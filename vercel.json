{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/kai-review",
      "schedule": "0 12 * * 1-5"
    },
    {
      "path": "/api/kai-review",
      "schedule": "0 17 * * 1-5"
    }
  ]
}
